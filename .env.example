# CardDAV credentials (any compliant server: Fastmail, iCloud, Nextcloud, Radicale…)
CARDDAV_USERNAME=you@example.com
CARDDAV_PASSWORD=

# Todoist API
# Get your token at https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=
# Todoist project name (case-insensitive) where birthday tasks are created
TODOIST_PROJECT_NAME=Birthdays

# CardDAV base URL. Defaults to Fastmail if unset.
# CARDDAV_URL=https://carddav.fastmail.com/dav/
#
# Examples for other providers:
# Fastmail:    CARDDAV_URL=https://carddav.fastmail.com/dav/
# iCloud:      CARDDAV_URL=https://contacts.icloud.com/
# Nextcloud:   CARDDAV_URL=https://cloud.example.com/remote.php/dav/
# Radicale:    CARDDAV_URL=https://radicale.example.com/
# Baïkal:      CARDDAV_URL=https://baikal.example.com/dav.php/
# SOGo:        CARDDAV_URL=https://sogo.example.com/SOGo/dav/

# Optional: logging
# LOG_LEVEL=INFO
# LOG_FILE=logs/sync.log
# LOG_MAX_BYTES=1048576
# LOG_BACKUP_COUNT=5
